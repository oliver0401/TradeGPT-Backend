PORT=4000

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your-password
DB_NAME=tradegpt

JWT_SECRET=change-me-to-a-long-random-string

# Maileroo (email verification)
MAILEROO_API_KEY=your-maileroo-sending-key
MAILEROO_API_URL=https://smtp.maileroo.com/api/v2/emails
MAILEROO_FROM=noreply@your-verified-domain.com
MAILEROO_FROM_NAME=TradeGPT

# OpenAI (TradeGPT chat — model is chosen per message; web search uses search-preview models when needed)
OPENAI_API_KEY=
# Optional: model for suggested follow-up questions after each reply (default: gpt-4o-mini)
# OPENAI_SUGGESTIONS_MODEL=gpt-4o-mini

# Server public URL (required for CryptAPI payment webhooks — use ngrok in dev)
SERVER_URL=http://localhost:4000

# Payment destination addresses per network (networks without an address are hidden)
PAY_ADDRESS_ETH=0x557E1758962e6d2e8bEA5Aa727039843E618256d
PAY_ADDRESS_BSC=0x557E1758962e6d2e8bEA5Aa727039843E618256d
# PAY_ADDRESS_TRON=T...   (uncomment and set a TRC-20 address to enable Tron)
# PAY_ADDRESS_SOL=...     (uncomment and set a Solana address to enable Solana)
